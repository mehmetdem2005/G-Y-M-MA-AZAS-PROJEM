## 💳 4. ÖDEME WEBHOOK (İDEMPOTENT + PCI GÜVENLİ)
`apps/api/src/payments/webhook.controller.ts`
```typescript
import { Controller, Post, RawBodyRequest, Req, Headers } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';
import Redis from 'ioredis';
import * as crypto from 'crypto';

@Controller('webhooks')
export class PaymentWebhookController {
  private redis = new Redis(process.env.REDIS_URL!);

  constructor(private prisma: PrismaService) {}

  @Post('stripe')
  async handleStripe(@Req() req: RawBodyRequest<Request>, @Headers('stripe-signature') sig: string) {
    const endpointSecret = process.env.STRIPE_WEBHOOK_SECRET!;
    
    // 1. İmza doğrulama (PCI/OWASP)
    const event = require('stripe')(process.env.STRIPE_SECRET!).webhooks.constructEvent(
      req.rawBody, sig, endpointSecret
    );

    const eventId = event.id;
    // 2. İdempotency kontrolü
    const processed = await this.redis.sadd('webhook:processed', eventId);
    if (!processed) return { received: true };

    // 3. Sipariş state machine
    if (event.type === 'payment_intent.succeeded') {
      const pi = event.data.object;
      await this.prisma.order.update({
        where: { paymentIntentId: pi.id },
        data: { status: 'PAID' }
      });
    }

    await this.prisma.auditLog.create({
      data: { action: 'WEBHOOK_RECEIVED', entity: event.type, newData: { eventId } }
    });

    return { received: true };
  }
}
```
✅ **Standart Uyumları**:
- PCI DSS: Kart verisi webhook'ta gelmez, sadece `payment_intent.id`
- OWASP: Signature verification, idempotency key, rawBody middleware gerektirir
- ACID: Prisma transaction içinde state güncelleme

