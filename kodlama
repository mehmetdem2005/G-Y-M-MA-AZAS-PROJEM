import { Injectable } from '@nestjs/common';
import { CarrierAdapter } from '../carrier.interface';
import * as axios from 'axios';
import * as bwipjs from 'bwip-js';

@Injectable()
export class YurticiAdapter implements CarrierAdapter {
  private api = axios.create({ baseURL: process.env.YURTICI_API_URL, timeout: 5000 });

  async createShipment(order: any) {
    // ERP/Carrier API çağrısı (mock)
    const { data } = await this.api.post('/shipment', {
      orderRef: order.id,
      sender: process.env.WAREHOUSE_CODE,
      receiver: { name: order.shippingName, address: order.shippingAddress, phone: order.shippingPhone }
    });

    // ISO 15416 Barkod üretimi
    const barcodePng = await bwipjs.toBuffer({ bcid: 'code128', text: data.trackingNo, scale: 3, height: 10 });
    const labelUrl = await this.uploadToS3(barcodePng, `labels/${data.trackingNo}.png`);
    
    return { trackingNo: data.trackingNo, labelUrl };
  }

  async track(trackingNo: string) {
    const { data } = await this.api.get(`/track/${trackingNo}`);
    return { status: data.status, location: data.location, lastUpdate: data.timestamp };
  }

  async cancel(trackingNo: string) {
    await this.api.post(`/cancel/${trackingNo}`);
  }

  private async uploadToS3(buffer: Buffer, key: string) {
    // AWS S3 upload stub
    return `https://cdn.fashion-ecommerce.com/${key}`;
  }
