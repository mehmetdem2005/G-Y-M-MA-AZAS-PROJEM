const fetcher = (url: string) => fetch(url).then(res => res.json());

const STATUS_FLOW = {
  PAID: 'FULFILLING',
  FULFILLING: 'SHIPPED',
  SHIPPED: 'DELIVERED',
  DELIVERED: 'REFUNDED'
};

export default function OrdersPage() {
  const { data } = useSWR('/api/admin/orders?status=PAID,FULFILLING,SHIPPED', fetcher);
