                <td className="px-4 py-2">{o.customerEmail}</td>
                <td className="px-4 py-2">
                  <span className={`px-2 py-0.5 rounded text-xs ${
                    o.status === 'PAID' ? 'bg-blue-100 text-blue-800' :
                    o.status === 'FULFILLING' ? 'bg-yellow-100 text-yellow-800' :
                    'bg-green-100 text-green-800'
                  }`}>{o.status}</span>
                </td>
                <td className="px-4 py-2">{o.totalAmount} ₺</td>
                <td className="px-4 py-2">
                  {STATUS_FLOW[o.status as keyof typeof STATUS_FLOW] && (
                    <button
                      onClick={() => transitionStatus(o.id, o.status)}
                      className="text-sm px-2 py-1 bg-primary text-white rounded hover:bg-primary/90 focus:outline-none focus:ring-2"
                    >
                      {STATUS_FLOW[o.status as keyof typeof STATUS_FLOW]} →
                    </button>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  );
}
