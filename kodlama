```typescript
import { Injectable } from '@nestjs/common';
import { RedisService } from '../redis/redis.service';

@Injectable()
export class ShippingService {
  private readonly RATES = {
    standard: { base: 29.90, perKg: 5.50, freeThreshold: 500 },
    express:  { base: 59.90, perKg: 8.00 }
  };

  constructor(private redis: RedisService) {}

  async calculate({ weightKg, province, cartTotal }: { weightKg: number; province: string; cartTotal: number }) {
    const cacheKey = `ship:${province}:${Math.round(cartTotal)}:${weightKg.toFixed(1)}`;
    const cached = await this.redis.get(cacheKey);
    if (cached) return JSON.parse(cached);

    let cost = this.RATES.standard.base + (weightKg * this.RATES.standard.perKg);
    if (cartTotal >= this.RATES.standard.freeThreshold) cost = 0;

    const result = {
      standard: { cost: Math.max(0, cost), days: '2-4' },
      express:  { cost: this.RATES.express.base + (weightKg * this.RATES.express.perKg), days: '1-2' }
    };

    await this.redis.setex(cacheKey, 1800, JSON.stringify(result)); // 30dk cache
    return result;
  }
}
```
