## 🛒 3. REDIS SEPET + ATOMİK STOK KİLİDİ
`apps/api/src/cart/cart.service.ts`
```typescript
import { Injectable, ConflictException } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';
import Redis from 'ioredis';

@Injectable()
export class CartService {
  private redis: Redis;
  private LOCK_SCRIPT = `
    local stock = tonumber(redis.call('GET', KEYS[1]))
    if stock and stock >= tonumber(ARGV[1]) then
      redis.call('DECRBY', KEYS[1], ARGV[1])
      redis.call('INCRBY', KEYS[1] .. ':reserved', ARGV[1])
      return 1
    end
    return 0
  `;

  constructor(private prisma: PrismaService) {
    this.redis = new Redis(process.env.REDIS_URL!);
  }

  async addToCart(userId: string | null, variantId: string, qty: number = 1) {
    // 1. Stok kilidi (Lua atomic)
    const reserved = await this.redis.eval(this.LOCK_SCRIPT, 1, `stock:${variantId}`, qty.toString());
    if (!reserved) throw new ConflictException('Yetersiz stok. Lütfen adet kontrol edin.');

    // 2. Sepet güncelleme (Upsert)
    const cartId = userId ? `cart:u:${userId}` : `cart:s:${this.generateSessionId()}`;
    await this.redis.hset(cartId, { variantId, qty, addedAt: Date.now() });
    await this.redis.expire(cartId, 900); // 15dk TTL

    // 3. Audit
    await this.prisma.auditLog.create({
      data: { userId, action: 'CART_ADD', entity: variantId, newData: { qty } }
    });

    return { success: true, ttl: 900 };
  }

  private generateSessionId() {
    return require('crypto').randomBytes(16).toString('hex');
  }
}
```
✅ **Standart Uyumları**:
- CAP Teoremi: Stok için Consistency öncelikli (Lua atomic)
- OWASP: Idempotent, race-condition korumalı
- KVKK: Session ID rastgele, IP/UA loglanabilir, TTL ile veri minimizasyonu

