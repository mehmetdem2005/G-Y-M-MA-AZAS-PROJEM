-- dbt ile LTV:CAC ve Cohort Retention
WITH cohort AS (
  SELECT 
    user_id,
    DATE_TRUNC('month', created_at) AS cohort_month,
    SUM(total_amount) AS ltv
  FROM {{ ref('orders') }}
  WHERE status = 'PAID'
  GROUP BY 1, 2
),
cac AS (
  SELECT DATE_TRUNC('month', acquired_at) AS month, AVG(cost) AS avg_cac
  FROM {{ ref('marketing_spend') }}
  GROUP BY 1
)
SELECT 
  c.cohort_month,
  c.ltv,
  ca.avg_cac,
  c.ltv / NULLIF(ca.avg_cac, 0) AS ltv_cac_ratio
FROM cohort c
LEFT JOIN cac ca ON c.cohort_month = ca.month;
