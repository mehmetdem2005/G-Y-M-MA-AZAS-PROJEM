    });
    mutate('/api/admin/orders?status=PAID,FULFILLING,SHIPPED');
  };

  return (
    <section aria-labelledby="orders-title">
      <h1 id="orders-title" className="text-2xl font-bold mb-4">Sipariş Yönetimi</h1>
