import { Injectable, CanActivate, ExecutionContext, ForbiddenException } from '@nestjs/common';
import { OpaClient } from '@open-policy-agent/opa-node';

@Injectable()
export class OpaGuard implements CanActivate {
  private opa = new OpaClient({ host: process.env.OPA_URL || 'http://localhost:8181' });

  async canActivate(ctx: ExecutionContext): Promise<boolean> {
    const req = ctx.switchToHttp().getRequest();
    const policyInput = {
      input: {
        method: req.method,
        path: req.path,
        user: req.user,
        ip: req.ip,
        headers: req.headers
      }
    };

    const { result } = await this opa.query('data.api.authz.allow', policyInput);
    if (!result) throw new ForbiddenException('Policy violation: Access denied');
    return true;
  }
}
