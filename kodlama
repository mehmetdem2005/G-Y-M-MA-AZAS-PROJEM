import { Injectable, Inject } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';
import { BullQueue, InjectQueue } from '@nestjs/bull';
import { YurticiAdapter } from './carriers/yurtici.adapter';

@Injectable()
export class LogisticsService {
  constructor(
    private prisma: PrismaService,
    @InjectQueue('shipping') private shippingQueue: BullQueue,
    private carrier: YurticiAdapter
  ) {}

  async processPaidOrder(orderId: string) {
    await this.shippingQueue.add('createShipment', { orderId }, { attempts: 3, backoff: 'exponential' });
  }

  @Bull('shipping')
  async handleCreateShipment(job: any) {
    const { orderId } = job.data;
    const order = await this.prisma.order.findUnique({ where: { id: orderId } });
    if (!order || order.status !== 'PAID') throw new Error('Invalid order state');

    const { trackingNo, labelUrl } = await this.carrier.createShipment(order);
    await this.prisma.order.update({
      where: { id: orderId },
       { status: 'SHIPPED', trackingNumber: trackingNo, shippingLabel: labelUrl }
    });
  }
}
