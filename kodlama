`apps/web/middleware.ts` (Locale Routing)
```typescript
import createMiddleware from 'next-intl/middleware';
import { NextRequest, NextResponse } from 'next/server';

const intlMiddleware = createMiddleware({
  locales: ['tr', 'en', 'de', 'ar'],
  defaultLocale: 'tr',
  localePrefix: 'as-needed'
});

export default function middleware(req: NextRequest) {
  // 1. Locale detection (cookie → header → path → fallback)
  const response = intlMiddleware(req);
  
  // 2. RTL/CSS direction enjekte et
  const dir = req.nextUrl.pathname.startsWith('/ar') ? 'rtl' : 'ltr';
  response.headers.set('X-Direction', dir);
  
  // 3. GDPR/KVKK: locale-specific consent banner
  const consent = req.cookies.get('consent_locale');
  if (!consent) {
    response.cookies.set('consent_locale', req.nextUrl.locale || 'tr', { path: '/', maxAge: 31536000 });
  }
  
  return response;
}

export const config = { matcher: ['/', '/(tr|en|de|ar)/:path*'] };
