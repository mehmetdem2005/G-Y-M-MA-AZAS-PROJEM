import { Injectable, NestMiddleware } from '@nestjs/common';
import { Request, Response, NextFunction } from 'express';

@Injectable()
export class ABTestMiddleware implements NestMiddleware {
  use(req: Request, res: Response, next: NextFunction) {
    const variant = Math.random() < 0.5 ? 'A' : 'B';
    req.headers['x-ab-variant'] = variant;
    req.headers['x-ab-session-id'] = req.cookies['ab_session'] || crypto.randomUUID();
    
    // Cookie set (14 gün)
    res.cookie('ab_session', req.headers['x-ab-session-id'], { httpOnly: true, maxAge: 14 * 24 * 60 * 60 * 1000 });
    next();
  }
}
