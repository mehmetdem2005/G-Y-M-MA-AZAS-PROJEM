// 🌐 Webhook İdempotency (TASK-3.1)
app.post('/webhooks/payment', async (req, res) => {
  const sig = req.headers['stripe-signature'];
  if (!stripe.webhooks.constructEvent(req.body, sig, endpointSecret)) return res.status(400);
  
  const { id: eventId, type } = req.body.data.object;
  const processed = await redis.sadd('webhook:processed', eventId);
  if (!processed) return res.status(200); // Idempotent ignore
  
  await orderService.updateFromWebhook(type, req.body.data.object);
  res.status(200).json({ received: true });
});
