## 🔄 CI/CD PIPELINE (GitHub Actions)

```yaml
name: CI/CD Pipeline
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  quality:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v2
      - run: pnpm install
      - run: pnpm lint && pnpm type-check
      - run: pnpm test -- --coverage
      - uses: actions/upload-artifact@v4
        with: { name: coverage, path: coverage/ }

  security:
    needs: quality
    runs-on: ubuntu-latest
    steps:
      - run: npm audit --production --audit-level=high
      - run: npx owasp-zap-baseline-scan -t https://staging-api.example.com
      - run: trivy image fashion-ecommerce/api:latest --severity HIGH,CRITICAL

  deploy-staging:
    needs: [quality, security]
    if: github.ref == 'refs/heads/main'
    runs-on: ubuntu-latest
    steps:
      - run: echo "Deploying to staging..."
      - run: kubectl apply -f infra/k8s/staging/
      - run: sleep 30 && curl -f https://staging-api.example.com/healthz

  deploy-prod:
    needs: deploy-staging
    if: github.ref == 'refs/heads/main'
    runs-on: ubuntu-latest
    environment: production
    steps:
      - run: kubectl apply -f infra/k8s/prod/ --strategy=blue-green
      - run: kubectl rollout status deployment/api-prod --timeout=300s
      - run: curl -f https://api.fashion-ecommerce.com/healthz
```

